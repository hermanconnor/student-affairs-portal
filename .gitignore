# ==========================================
# 1. Monorepo Dependencies & System Files
# ==========================================
node_modules/
**/node_modules/
.npm
.eslintcache
.stylelintcache
.cache/
**/.cache/

# ==========================================
# 2. Build Outputs (Express, Vite, Next.js)
# ==========================================
dist/
**/dist/
dist-ssr/
**/dist-ssr/
build/
**/build/
out/
**/out/

# Next.js specific build files (Kept for future-proofing)
.next/
**/.next/
next-env.d.ts

# TypeScript compilation cache
*.tsbuildinfo

# ==========================================
# 3. Environment Variables & Secrets
# ==========================================
.env
.env.*
.env*.local
!.env.example
*.pem

# Docker local secrets/override configurations
.env.docker
.env.production
.env.development

# Vercel deployment tracking
.vercel

# ==========================================
# 4. Logs, Diagnostics & Diagnostics Tests
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
coverage/
**/coverage/
.nyc_output/

# ==========================================
# 5. OS & IDE Specifics
# ==========================================
.DS_Store
Thumbs.db
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# VS Code (Ignores setting details but keeps recommended extensions)
.vscode/*
!.vscode/extensions.json

# ==========================================
# 6. Vite Tooling Artifacts
# ==========================================
.vite/
**/.vite/
.vitest/
**/.vitest/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*